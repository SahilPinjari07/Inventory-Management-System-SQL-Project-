#1.	Generate Monthly Sales Report (Find the best-selling months for vehicles.)
select date_format (sale_date,'%Y-%M')as month,sum(total_price) as total_sales from sales group by month order by total_sales desc limit 1;

#2.	Top Selling Vehicles Report (Find the most popular vehicle models.)
select vehicles.model_name,count(sales.sale_id) as total_sold from sales 
join vehicles on sales.vehicle_id= vehicles.vehicle_id 
group by vehicles.model_name order by total_sold desc limit 4;

#3.	Low Stock Alert for Spare Parts (Avoid outofstocks and ensure timely reorders.)
select part_name,stock_quantity,reorder_level from spare_parts where stock_quantity <= reorder_level; 

#4.	Sales Trends Over Time (For Growth Analysis for Track daily sales trends).
select date(sale_date) as day,sum(total_price) as daily_sales from sales group by day order by day;

#5.	Vehicle Stock Overview (Current Inventory  for Quick dashboard to see how many vehicles are in stock.)
select brand,model_name,stock_quantity from vehicles order by stock_quantity desc;

#6.	Spare Parts Sales Analysis.
select sp.part_name,sum(sps.quantity) as total_sold,sum(sps.total_price) as Revenue from spare_parts_sales sps
join spare_parts sp on sps.part_id = sp.part_id
group by sp.part_name
order by revenue desc;

#7.	Revenue by Salesperson(Recognize top-performing sales )
select u.username as salespeerson,sum(s.total_price) as total_revenue,count(s.sale_id) as total_sales from sales s 
join users u on s.user_id = u.user_id 
group by u.username
order by total_revenue desc;

#8.	Update Vehicle Stock After Sales.
Delimiter //
create trigger update_vehicle_stock
after insert on Sales
for each row
begin
update Vehicles
set stock_qty = stock_qty - 1
where vehicle_id = new.vehicle_id;
end;
//
show triggers;
select * from sales;

#9.	Update Spare Parts Stock After Sale.
Delimiter //
create trigger UpdateSparePartsStock 
after insert on spare_parts_sales
for each row 
begin
update Spare_parts set stock_quantity = stock_quantity -new.quantity where part_id = new.part_id;
end;
//
show triggers;
